# PostgreSQL Database Configuration
POSTGRES_HOST=db-origami-nur-3364.c.aivencloud.com
POSTGRES_PORT=19924
POSTGRES_DB=defaultdb
POSTGRES_USER=avnadmin
POSTGRES_PASSWORD=your_password_here

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Groq LLM Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
CLOUDINARY_API_SECRET=your_api_secret

# Model Configuration
ORIGAMI_EPOCHS=50
ORIGAMI_MIN_SAMPLES_PER_CLASS=3
ORIGAMI_MAX_CLASSES=50
ORIGAMI_REQUEST_CONNECT_TIMEOUT=4
ORIGAMI_REQUEST_READ_TIMEOUT=8
ORIGAMI_REQUEST_RETRIES=2
ORIGAMI_RETRY_BACKOFF_SEC=0.75

# Groq LLM Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile
